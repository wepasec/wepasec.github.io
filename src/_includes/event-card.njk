<div class="event-card">
  <img
    src="{{ event.data.image }}"
    alt="{{ event.data.title }} event flyer"
    class="event-thumb"
  />
  <div class="event-info">
    <h2 class="event-title">{{ event.data.title }}</h2>
    <p class="event-date"><strong>Date:</strong> {{ event.data.dateString }}</p>
    <p class="event-time">
      <strong>Time:</strong> {{ event.data.start }} – {{ event.data.end }}
    </p>
    <p class="event-price"><strong>Tickets:</strong> {{ event.data.price }}</p>
    {%- if event.data.upcoming -%}
    <a href="#" class="event-button open-popup"> Buy Tickets </a>
    <div class="popup-overlay">
      <div class="popup-content">
        <button class="popup-close">✕</button>
        <div
          data-hievents-id="{{ event.data.hieventsID }}"
          data-hievents-primary-color="#e33b3b"
          data-hievents-primary-text-color="#fff"
          data-hievents-secondary-color="#e82e2e"
          data-hievents-secondary-text-color="#ffffff"
          data-hievents-background-color="#000"
          data-hievents-widget-type="widget"
          data-hievents-widget-version="1.0"
          data-hievents-locale="en"
          data-hievents-padding="20px"
          data-hievents-autoresize="true"
          data-hievents-continue-button-text="Continue"
          class="hievents-widget"
        ></div>
      </div>
    </div>
    {%- endif -%}
  </div>
</div>
